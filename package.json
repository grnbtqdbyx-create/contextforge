{
  "name": "contextforge",
  "version": "0.61.0",
  "description": "Agent context gate for Codex, Claude Code, GitHub Copilot, MCP, Cursor, Cline, Gemini, and Windsurf repos.",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grnbtqdbyx-create/contextforge.git"
  },
  "homepage": "https://github.com/grnbtqdbyx-create/contextforge#readme",
  "bugs": {
    "url": "https://github.com/grnbtqdbyx-create/contextforge/issues"
  },
  "bin": {
    "contextforge": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "assets",
    "docs",
    "examples",
    "fixtures",
    "llms.txt",
    "llms-full.txt",
    "contextforge-publish-readiness.md",
    "contextforge-scorecard.md",
    "contextforge-agent-surface-map.md",
    "contextforge-mcp-audit.md",
    "contextforge-claude-audit.md",
    "contextforge-trace-audit.md",
    "contextforge-cost-estimate.md",
    "contextforge-pack.md",
    "README.md",
    "LICENSE",
    "NOTICE",
    "TRADEMARKS.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "contextforge": "tsx src/cli.ts"
  },
  "keywords": [
    "ai",
    "llm",
    "codex",
    "claude-code",
    "context-engineering",
    "token-usage",
    "prompt-caching",
    "coding-agents",
    "agent-readiness",
    "mcp",
    "agent-security",
    "context-audit",
    "developer-tools",
    "cli",
    "cursor",
    "cline",
    "gemini-cli",
    "windsurf",
    "typescript"
  ],
  "author": "Ogün Keskin",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
