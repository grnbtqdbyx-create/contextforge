{
  "name": "contextforge",
  "version": "0.38.0",
  "description": "Self-learning token and context optimizer for Codex and Claude Code.",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "bin": {
    "contextforge": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "assets",
    "docs",
    "examples",
    "fixtures",
    "llms.txt",
    "llms-full.txt",
    "README.md",
    "LICENSE",
    "NOTICE",
    "TRADEMARKS.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "contextforge": "tsx src/cli.ts"
  },
  "keywords": [
    "ai",
    "llm",
    "codex",
    "claude-code",
    "context-engineering",
    "token-usage",
    "prompt-caching",
    "coding-agents",
    "agent-readiness",
    "context-audit",
    "developer-tools",
    "cli",
    "typescript"
  ],
  "author": "Ogün Keskin",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
